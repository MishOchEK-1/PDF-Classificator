<mxfile host="app.diagrams.net">
  <diagram name="PDF Classification Architecture">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Web UI -->
        <mxCell id="2" value="Web UI&#xa;(HTML/CSS/JS Upload Page)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e3a5f;strokeColor=#6c8ebf;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="40" width="260" height="90" as="geometry"/>
        </mxCell>

        <!-- Backend -->
        <mxCell id="3" value="Django Backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f4d1f;strokeColor=#82b366;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="190" width="260" height="90" as="geometry"/>
