        <!-- PDF Parser -->
        <mxCell id="5" value="PDF Parser&#xa;(Text Extraction)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#665200;strokeColor=#d6b656;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="380" width="220" height="80" as="geometry"/>
